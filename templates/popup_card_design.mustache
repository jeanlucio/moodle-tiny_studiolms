{{!
    @template tiny_studiolms/popup_card_design
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>

    Example context (json): {
        "bg": "#ffffff", "text": "#212529", "border": "#0d47a1", "radius": 8
    }
}}
<div class="d-flex justify-content-between align-items-center mb-3">
    <label for="pop_card_bg" class="form-label m-0 small fw-bold text-muted">{{#str}} bg_color, tiny_studiolms {{/str}}</label>
    <input type="color" class="slms-color-picker" id="pop_card_bg" value="{{bg}}">
</div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <label for="pop_card_text" class="form-label m-0 small fw-bold text-muted">{{#str}} text_color, tiny_studiolms {{/str}}</label>
    <input type="color" class="slms-color-picker" id="pop_card_text" value="{{text}}">
</div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <label for="pop_card_border" class="form-label m-0 small fw-bold text-muted">{{#str}} border_color, tiny_studiolms {{/str}}</label>
    <input type="color" class="slms-color-picker" id="pop_card_border" value="{{border}}">
</div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <label for="pop_card_radius" class="form-label m-0 small fw-bold text-muted">{{#str}} border_radius, tiny_studiolms {{/str}}</label>
    <input type="number" class="form-control form-control-sm slms-input-number" id="pop_card_radius" value="{{radius}}" min="0" max="50">
</div>
<div class="mb-1">
    <label for="pop_card_shadow" class="form-label small fw-bold text-muted">{{#str}} shadow, tiny_studiolms {{/str}}</label>
    <select class="form-select form-select-sm" id="pop_card_shadow">
        <option value="none" {{#shadow_none}}selected{{/shadow_none}}>{{#str}} shadow_none, tiny_studiolms {{/str}}</option>
        <option value="sm" {{#shadow_sm}}selected{{/shadow_sm}}>{{#str}} shadow_sm, tiny_studiolms {{/str}}</option>
        <option value="md" {{#shadow_md}}selected{{/shadow_md}}>{{#str}} shadow_md, tiny_studiolms {{/str}}</option>
        <option value="lg" {{#shadow_lg}}selected{{/shadow_lg}}>{{#str}} shadow_lg, tiny_studiolms {{/str}}</option>
    </select>
</div>
