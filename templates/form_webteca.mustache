{{!
    @template tiny_studiolms/form_webteca
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>

    Example context (json): {
        "title": "Materiais de Apoio",
        "description": "Recursos complementares.",
        "titleColor": "#1e293b",
        "descColor": "#64748b",
        "isGrid": false,
        "isAccordion": true,
        "enableHover": true,
        "enableSoundHover": false,
        "enableSoundClick": false
    }
}}
<div class="mb-3">
    <h6 class="fw-bold border-bottom pb-2 mb-3 text-dark">
        <span aria-hidden="true" class="me-2">⚙️</span> {{#str}} wt_general, tiny_studiolms {{/str}}
    </h6>

    <div class="mb-2">
        <label for="wt_title" class="form-label small fw-bold text-muted mb-1">{{#str}} wt_title, tiny_studiolms {{/str}}</label>
        <input type="text" class="form-control form-control-sm" id="wt_title" value="{{title}}">
    </div>

    <div class="mb-2">
        <label for="wt_desc" class="form-label small fw-bold text-muted mb-1">{{#str}} wt_desc, tiny_studiolms {{/str}}</label>
        <input type="text" class="form-control form-control-sm" id="wt_desc" value="{{description}}">
    </div>

    <div class="d-flex gap-2 mb-3">
        <div style="flex: 1;">
            <label for="wt_layout" class="form-label small fw-bold text-muted mb-1">{{#str}} layout, tiny_studiolms {{/str}}</label>
            <select class="form-select form-select-sm" id="wt_layout">
                <option value="list" {{^isGrid}}selected{{/isGrid}}>{{#str}} wt_layout_list, tiny_studiolms {{/str}}</option>
                <option value="grid" {{#isGrid}}selected{{/isGrid}}>{{#str}} wt_layout_grid, tiny_studiolms {{/str}}</option>
            </select>
        </div>
        <div>
            <label for="wt_title_color" class="form-label small fw-bold text-muted mb-1">{{#str}} text_color, tiny_studiolms {{/str}}</label>
            <input type="color" class="slms-color-picker d-block" id="wt_title_color" value="{{titleColor}}">
        </div>
    </div>

    <div class="border rounded p-2 bg-light mb-2">
        <div class="form-check form-switch mb-2">
            <input class="form-check-input ms-1" type="checkbox" id="wt_is_acc" {{#isAccordion}}checked{{/isAccordion}}>
            <label class="form-check-label small fw-bold text-dark ms-2" for="wt_is_acc">Usar formato Acordeão</label>
        </div>

        <div class="mt-2 pt-2 border-top">
            <label for="wt_acc_icon" class="form-label small fw-bold text-muted mb-1">{{#str}} acc_icon, tiny_studiolms {{/str}}</label>
            <select class="form-select form-select-sm" id="wt_acc_icon">
                <option value="▶">▶ Seta (Gira para baixo)</option>
                <option value="▼">▼ Seta (Gira para cima)</option>
                <option value="➕">➕ Expandir (Vira Menos)</option>
                <option value="📁">📁 Pasta (Abre/Fecha)</option>
                <option value="📕">📕 Livro (Abre/Fecha)</option>
                <option value="🔒">🔒 Cadeado (Abre/Fecha)</option>
                <option value="📥">📥 Caixa (Abre/Fecha)</option>
            </select>
        </div>
    </div>
</div>

<div class="mb-3 p-3 bg-light border rounded">
    <h6 class="small fw-bold text-primary mb-2">⚡ Interatividade & Sons</h6>
    <div class="form-check mb-2">
        <input class="form-check-input" type="checkbox" id="wt_hover" {{#enableHover}}checked{{/enableHover}}>
        <label class="form-check-label small" for="wt_hover">Efeito Hover (Zoom e Cor)</label>
    </div>
    <div class="d-flex gap-2 mb-2">
        <div style="flex: 1;">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="wt_snd_hover_chk" {{#enableSoundHover}}checked{{/enableSoundHover}}>
                <label class="form-check-label small" for="wt_snd_hover_chk">Som (Mouse)</label>
            </div>
            <input type="text" class="form-control form-control-sm mt-1" id="wt_snd_hover_url" value="{{soundHoverUrl}}" placeholder="URL do MP3">
        </div>
        <div style="flex: 1;">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="wt_snd_click_chk" {{#enableSoundClick}}checked{{/enableSoundClick}}>
                <label class="form-check-label small" for="wt_snd_click_chk">Som (Clique)</label>
            </div>
            <input type="text" class="form-control form-control-sm mt-1" id="wt_snd_click_url" value="{{soundClickUrl}}" placeholder="URL do MP3">
        </div>
    </div>
</div>

<div class="mb-2">
    <h6 class="fw-bold border-bottom pb-2 mb-3 text-dark">
        <span aria-hidden="true" class="me-2">📎</span> {{#str}} wt_items, tiny_studiolms {{/str}}
    </h6>
    <div id="slms-wt-items-container" class="d-flex flex-column gap-2 mb-3"></div>
    <button type="button" class="btn btn-sm btn-outline-primary w-100 fw-bold border-dashed" id="slms-wt-add-item">
        <span aria-hidden="true">+</span> {{#str}} wt_add_item, tiny_studiolms {{/str}}
    </button>
</div>
