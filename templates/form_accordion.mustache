{{!
    @template tiny_studiolms/form_accordion
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>

    Example context (json): {
        "title": "Tópico Expansível",
        "icon": "▼",
        "color": "#f0f9ff",
        "isOpen": false
    }
}}
<div class="mb-4">
    <h6 class="fw-bold border-bottom pb-2 mb-3 text-dark">
        <span aria-hidden="true" class="me-2">📝</span> {{#str}} configuration, tiny_studiolms {{/str}}
    </h6>

    <div class="mb-3">
        <label for="cfg_acc_title" class="form-label small fw-bold text-muted">{{#str}} acc_title, tiny_studiolms {{/str}}</label>
        <input type="text" class="form-control form-control-sm" id="cfg_acc_title" value="{{title}}">
    </div>

    <div class="mb-3">
        <label for="cfg_acc_icon" class="form-label small fw-bold text-muted">{{#str}} acc_icon, tiny_studiolms {{/str}}</label>
        <select class="form-select form-select-sm" id="cfg_acc_icon">
            <option value="▼">▼ {{#str}} icon_down, tiny_studiolms {{/str}}</option>
            <option value="▶">▶ {{#str}} icon_right, tiny_studiolms {{/str}}</option>
            <option value="➕">➕ {{#str}} icon_plus, tiny_studiolms {{/str}}</option>
            <option value="📂">📂 {{#str}} icon_folder, tiny_studiolms {{/str}}</option>
            <option value="💡">💡 {{#str}} icon_idea, tiny_studiolms {{/str}}</option>
            <option value="📌">📌 {{#str}} icon_pin, tiny_studiolms {{/str}}</option>
        </select>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <label for="cfg_acc_color" class="form-label m-0 small fw-bold text-muted">{{#str}} acc_color, tiny_studiolms {{/str}}</label>
        <input type="color" class="slms-color-picker" id="cfg_acc_color" value="{{color}}">
    </div>

    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="cfg_acc_open" {{#isOpen}}checked{{/isOpen}}>
        <label class="form-check-label small fw-bold text-muted" for="cfg_acc_open">{{#str}} acc_open, tiny_studiolms {{/str}}</label>
    </div>
</div>
