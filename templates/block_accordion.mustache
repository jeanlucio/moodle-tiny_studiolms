<div class="studiolms-accordion-wrap" style="margin: 1.5rem 0; max-width: 900px; width: 100%;">

    <details class="studiolms-accordion" data-initial-state="{{state}}" open style="border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; background-color: {{bg}};">

        <summary style="display: block; list-style: none; outline: none; cursor: pointer; margin: 0; padding: 0;">

            <span style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; font-weight: bold; font-size: 1.1rem; color: {{color}};">
                <span style="flex-grow: 1;">{{title}}</span>
                <span contenteditable="false" style="font-size: 0.9em; user-select: none; margin-left: 15px;">{{iconFirst}}</span>
            </span>

        </summary>

        <div class="studiolms-editable-area" style="padding: 1.5rem; border-top: 1px solid #e2e8f0; background: transparent; font-weight: normal; color: #212529;">
            <p style="margin-top: 0;">Escreva o conteúdo do tópico aqui. Pode usar as ferramentas do Moodle para adicionar imagens, listas e links.</p>
        </div>

    </details>
</div>
<p><br></p>
