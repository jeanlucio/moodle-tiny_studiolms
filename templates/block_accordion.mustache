{{!
    @template tiny_studiolms/block_accordion
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>

    Accordion skeleton injected into the Moodle editor.
    Example context (json): {
        "title": "Topic 1", "icon": "▼", "color": "#e0f2fe", "isOpen": false
    }
}}
<div class="studiolms-accordion-wrap" contenteditable="false" style="margin-bottom: 15px;">
    <details style="border: 1px solid #dce6f0; border-radius: 8px; background-color: #ffffff; overflow: hidden;" {{#isOpen}}open{{/isOpen}}>
        <summary style="padding: 12px 16px; cursor: pointer; font-weight: bold; background-color: {{color}}; color: #111827; display: flex; align-items: center; gap: 10px; outline: none;">
            <span aria-hidden="true" style="min-width: 24px; text-align: center; font-size: 1.1em;">{{icon}}</span>
            <span style="flex: 1;">{{title}}</span>
        </summary>
        <div contenteditable="true" style="padding: 20px; border-top: 1px solid #eef2f6; color: #334155; outline: none; min-height: 60px;">
            <p style="margin-top: 0;">{{#str}} default_accordion_text, tiny_studiolms {{/str}}</p>
        </div>
    </details>
</div>
<p><br></p>
