{{!
    @template tiny_studiolms/modal
    @copyright 2026 Jean Lúcio <jeanlucio@gmail.com>

    StudioLMS main modal interface (Native Moodle Modal) - Canva Style.

    Example context (json): {}
}}
<div class="tiny_studiolms container-fluid px-0" id="studiolms-app">

    <div id="slms-view-library">
        <div class="slms-library-grid" id="slms-library-grid">
            </div>
    </div>

    <div id="slms-view-editor" class="d-none position-relative">

        <div class="slms-header d-flex justify-content-between align-items-center">
            <button id="slms-btn-back" class="btn btn-outline-secondary rounded-pill btn-sm">
                <span aria-hidden="true">&larr;</span> {{#str}} back_to_library, tiny_studiolms {{/str}}
            </button>
            <h5 class="m-0 fw-bold text-dark fs-6" id="slms-editor-title">StudioLMS</h5>
            <button id="slms-btn-insert" class="btn btn-primary px-4 shadow-sm rounded-pill btn-sm">
                <span aria-hidden="true">🚀</span> {{#str}} insert_moodle, tiny_studiolms {{/str}}
            </button>
        </div>

        <div id="slms-top-toolbar" class="slms-toolbar d-flex align-items-center gap-2 mb-3" role="toolbar" aria-label="{{#str}} configuration, tiny_studiolms {{/str}}">
            </div>

        <div class="slms-canvas-area position-relative">
            <div class="slms-preview-panel" role="region" aria-label="{{#str}} preview, tiny_studiolms {{/str}}">
                <div id="slms-live-preview" class="w-100 shadow-sm bg-white rounded p-4" style="transform-origin: top center; transition: transform 0.2s ease-out;">
                    </div>
            </div>

            <div class="slms-zoom-controls shadow-sm" aria-hidden="true">
                <button type="button" id="slms-zoom-out" title="Zoom Out">−</button>
                <span id="slms-zoom-level">100%</span>
                <button type="button" id="slms-zoom-in" title="Zoom In">+</button>
            </div>
        </div>

        <div id="slms-popup-anchor" class="d-none" aria-hidden="true"></div>

    </div>
</div>
